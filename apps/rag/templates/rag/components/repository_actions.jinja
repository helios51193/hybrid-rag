{# apps/rag/templates/rag/components/repository_actions.jinja #}
<div class="join">
  <button
    class="btn btn-sm btn-primary join-item"
    {% if repo.status == "processing" %}disabled{% endif %}
    hx-post="{{ url('rag:process_repository', kwargs={'repo_id': repo.id}) }}"
    hx-target="#repo-row-{{ repo.id }}"
    hx-swap="outerHTML"
  >
    {% if repo.status == "processing" %}
      <span class="loading loading-spinner loading-xs"></span>
      Processing
    {% else %}
      Process
    {% endif %}
  </button>

  <a
    href="{{ url('rag:query_page') }}?repo_id={{ repo.id }}"
    class="btn btn-sm btn-accent join-item {% if repo.status != 'ready' %}btn-disabled{% endif %}"
    {% if repo.status != "ready" %}aria-disabled="true"{% endif %}
  >
    Query
  </a>

  <button
    class="btn btn-sm btn-error btn-outline join-item"
    {% if repo.status == "processing" %}disabled{% endif %}
    type="button"
    data-repo-id="{{ repo.id }}"
    data-repo-name="{{ repo.name }}"
    onclick="openDeleteRepositoryModal(this)"
  >
    Delete
  </button>
</div>
