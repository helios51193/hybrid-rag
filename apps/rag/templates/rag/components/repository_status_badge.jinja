{# apps/rag/templates/rag/components/repository_status_badge.jinja #}
{% if repo.status == "ready" %}
  <span class="badge badge-success">Ready</span>
{% elif repo.status == "processing" %}
  {% include "rag/components/repository_progress.jinja" %}
{% elif repo.status == "failed" %}
  <span class="badge badge-error">Failed</span>
{% else %}
  <span class="badge badge-ghost">Not Processed</span>
{% endif %}
