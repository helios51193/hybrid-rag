<div id="citations-panel" class="card bg-base-100 shadow-sm border border-base-300 h-full">
  <div class="card-body p-3 h-full min-h-0">
    <div class="flex items-center justify-between">
      <h2 class="card-title text-base">Citations</h2>
      <button class="btn btn-xs btn-ghost">View All</button>
    </div>
    <div class="divider my-1"></div>

    {% if citations %}
      <div class="space-y-2 overflow-y-auto min-h-0 h-full pr-1">
        {% for citation in citations %}
          <div class="rounded-box border border-base-300 p-2">
            <div class="text-sm font-medium">{{ citation.file_path }}</div>
            <div class="text-xs text-base-content/70">
              Line {{ citation.start_line }}-{{ citation.end_line }}
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="alert alert-info overflow-y-auto">
        <span>No citations yet. Run a query to populate this panel.</span>
      </div>
    {% endif %}
  </div>
</div>
