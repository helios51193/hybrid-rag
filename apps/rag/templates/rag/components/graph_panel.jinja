<div id="graph-panel" class="card bg-base-100 shadow-sm border border-base-300 h-full min-w-0 overflow-hidden">
  <div class="card-body p-3 h-full min-h-0 min-w-0 overflow-hidden">
    <div class="flex items-center justify-between gap-2">
      <h2 class="card-title text-base">Codebase Graph</h2>
      <div class="flex items-center gap-2 flex-wrap justify-end">
        <div class="text-xs text-base-content/60">Project: {{ selected_project_id if selected_project_id else "N/A" }}</div>
        <button type="button" id="graph-open-controls" class="btn btn-xs btn-outline">Controls</button>
        <button type="button" class="btn btn-xs btn-outline" onclick="resetCodebaseGraph()">Reset Graph</button>
      </div>
    </div>
    <div class="divider my-1"></div>
    <div class="mb-2 flex flex-wrap gap-1.5 text-[11px]">
      <span class="badge badge-outline border-blue-400 text-blue-400">Node: File</span>
      <span class="badge badge-outline border-emerald-400 text-emerald-400">Node: Class</span>
      <span class="badge badge-outline border-violet-400 text-violet-400">Node: Function/Method</span>
      <span class="badge badge-outline border-sky-300 text-sky-300">Edge: calls</span>
      <span class="badge badge-outline border-emerald-300 text-emerald-300">Edge: defines</span>
      <span class="badge badge-outline border-red-300 text-red-300">Edge: inherits</span>
      <span class="badge badge-outline border-pink-300 text-pink-300">Edge: test_targets</span>
      <span class="badge badge-outline border-gray-400 text-gray-400">Edge: imports</span>
    </div>

    <input type="hidden" id="graph-project-id" value="{{ selected_project_id if selected_project_id else '' }}">
    <script id="graph-elements-json" type="application/json">{{ graph_elements_json | safe }}</script>
    <div id="graph-empty-state" class="alert alert-info mb-2 {{ '' if graph_is_empty_state else 'hidden' }}">
      <span>Run a query to visualize a focused subgraph.</span>
    </div>
    <div
      id="codebase-graph-canvas"
      class="w-full h-full min-h-0 min-w-0 rounded-box bg-base-200 border border-base-300 overflow-hidden {{ 'hidden' if graph_is_empty_state else '' }}"
    ></div>
  </div>
</div>
