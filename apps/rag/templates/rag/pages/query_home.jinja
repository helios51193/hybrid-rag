{% extends "rag/base.jinja" %}

{% block title %}Conversations | Code Intelligence{% endblock %}

{% block content %}
<div class="max-w-4xl mx-auto space-y-4">
  <div class="card bg-base-100 shadow-sm border border-base-300">
    <div class="card-body">
      <h1 class="text-lg font-semibold">Conversations</h1>
      <p class="text-sm text-base-content/70">
        Project: {{ selected_project_id if selected_project_id else "No project selected" }}
      </p>
      <div class="mt-2">
        {% if selected_repo_id %}
          <a
            class="btn btn-primary btn-sm"
            href="{{ url('rag:query_start') }}?repo_id={{ selected_repo_id }}"
          >
            Start New Conversation
          </a>
        {% else %}
          <button class="btn btn-primary btn-sm" disabled>Start New Conversation</button>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="card bg-base-100 shadow-sm border border-base-300">
    <div class="card-body">
      <h2 class="card-title text-base">Past Conversations</h2>
      {% if conversation_rows %}
        <div class="overflow-x-auto">
          <table class="table table-zebra">
            <thead>
              <tr>
                <th>Title</th>
                <th>Updated</th>
                <th class="text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              {% for conv in conversation_rows %}
                <tr>
                  <td>{{ conv.title if conv.title else ("Conversation " ~ conv.id) }}</td>
                  <td>{{ conv.updated_at }}</td>
                  <td class="text-right">
                    <div class="inline-flex gap-1">
                      <a
                        class="btn btn-xs btn-outline"
                        href="{{ url('rag:query_page') }}?repo_id={{ selected_repo_id }}&conversation_id={{ conv.id }}"
                      >
                        Open
                      </a>
                      <form
                        method="post"
                        action="{{ url('rag:delete_conversation', kwargs={'conversation_id': conv.id}) }}"
                        onsubmit="return confirm('Delete this conversation?');"
                        class="inline"
                      >
                        <input type="hidden" name="csrfmiddlewaretoken" value="{{ csrf_token if csrf_token is defined else '' }}" />
                        <input type="hidden" name="repo_id" value="{{ selected_repo_id if selected_repo_id else '' }}" />
                        <button type="submit" class="btn btn-xs btn-error btn-outline">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      {% else %}
        <div class="alert alert-info">
          <span>No conversations yet. Start a new conversation to begin querying this project.</span>
        </div>
      {% endif %}
    </div>
  </div>
</div>
{% endblock %}
